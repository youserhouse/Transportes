rules_version = '2';

// ═══════════════════════════════════════════════════════════════
// Reglas de seguridad de Firestore para el proyecto transporte-99482.
//
// Este archivo refleja las reglas YA DESPLEGADAS en la consola de
// Firebase (verificado 2026-06-30) — se versiona aquí únicamente para
// tener historial de cambios en git. Si editas las reglas en la
// consola, actualiza también este archivo (o despliega este archivo
// con `firebase deploy --only firestore:rules` para que ambos sigan
// coincidiendo).
//
// Lo que hacen: replican del lado del servidor el mismo control de
// acceso que index.html / login.html aplican en el cliente (chequeo
// contra la colección authorized_users). Firestore deniega por
// defecto cualquier operación no permitida explícitamente, así que
// no hace falta una regla "catch-all" al final.
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {
    match /authorized_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
    }

    match /calculos/{docId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email));
    }
  }
}
